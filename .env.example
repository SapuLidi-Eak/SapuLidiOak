# Database (required) - add PostgreSQL in Railway dashboard, then copy DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/database

# Server
PORT=5000

# Auth - change in production
SESSION_SECRET=your-super-secret-jwt-key-change-this

# Optional: for Discord bot HWID reset (POST /api/reset-hwid)
# BOT_SECRET=your-bot-secret

# Node
NODE_ENV=production
